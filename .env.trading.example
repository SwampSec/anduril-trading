# Anduril Trading Suite -- API Keys
# Copy to ~/TradingSetup/.env.trading after install (or before first launch).
# Never commit the real .env.trading file.
# ─────────────────────────────────────────────────────────

# FINNHUB -- free at https://finnhub.io  (60 calls/min)
# Used for: live quotes, Level 2, news, earnings, analyst data, IPO calendar
FINNHUB_API_KEY=YOUR_KEY_HERE

# NEWSDATA.IO -- free at https://newsdata.io (200 credits/day)
# Used for: live news feed, geopolitical, macro, markets
NEWSDATA_API_KEY=YOUR_KEY_HERE

# TWELVE DATA -- free at https://twelvedata.com (800 calls/day)
# Used for: price history fallback, forex pairs, chart fallback
TWELVE_DATA_API_KEY=YOUR_KEY_HERE

# ALWAYS FREE (no key needed)
# Yahoo Finance : yfinance -- price history, charts, financials
