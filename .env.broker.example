# Broker / IBKR (official ibapi — install via scripts/install_ibapi.sh, not PyPI)
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=7
IBKR_ACCOUNT=
IBKR_READ_ONLY=true
IBKR_CONNECT_TIMEOUT_S=15
IBKR_REQUEST_TIMEOUT_S=10

# FastAPI control plane (localhost only)
API_HOST=127.0.0.1
API_PORT=9001
# Dashboard reads this (optional override)
# ANDURIL_API_BASE=http://127.0.0.1:9001

# LM Studio — use "auto" to pick the loaded model from GET /v1/models
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=auto
LMSTUDIO_API_KEY=lm-studio

# Bot
BOT_ENABLED=false
BOT_SYMBOLS=SPY
BOT_POLL_INTERVAL_SEC=60

# Live trading gates (see SECURITY.md T8)
# ANDURIL_INTENDED_MODE=paper
# LIVE_TRADING_CONFIRMED=0
# ANDURIL_KILL_SWITCH=0
